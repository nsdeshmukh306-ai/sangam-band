# Copy this file to .env and fill in real values. Never commit .env.

# --- Band platform connection ---
# Optional: only set these if you need to point at a non-default Band
# deployment. Leave unset to use band-sdk's built-in defaults
# (wss://app.band.ai/api/v1/socket/websocket and https://app.band.ai).
BAND_REST_URL=
BAND_WS_URL=

# --- LLM provider for all 6 agents (DeepSeek, OpenAI-compatible API) ---
DEEPSEEK_API_KEY=sk-...

# --- Personal/account-level Band API key, used by orchestrator/band_client.py
# for REST calls (create room, post messages, poll history).
# [VERIFY AGAINST DOCS in Phase 3 — exact env var name / scope at
#  docs.band.ai/getting-started/setup]
BAND_USER_API_KEY=

# --- Optional: Sangam Case Room id, once created (Section 7.4) ---
BAND_ROOM_ID=

# --- Optional partner-prize integrations (Phase 4 stretch, skip if unused) ---
AIML_API_KEY=
FEATHERLESS_API_KEY=
