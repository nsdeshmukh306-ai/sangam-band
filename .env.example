# ── Sangam environment template ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# --- LLM provider (DeepSeek via OpenAI-compatible API) ---
DEEPSEEK_API_KEY=sk-...

# --- Band platform ---
# Optional: leave unset to use band-sdk defaults (https://app.band.ai/)
BAND_REST_URL=
BAND_WS_URL=

# Personal/account-level Band API key (used by orchestrator/band_client.py)
BAND_USER_API_KEY=

# Sangam Case Room ID (from Band dashboard after manual setup)
BAND_ROOM_ID=9b4efd3c-46d2-4c40-8b33-d75dda925b05

# --- Backend ---
# Log level for FastAPI backend (DEBUG | INFO | WARNING)
LOG_LEVEL=INFO

# --- Optional partner-prize integrations ---
AIML_API_KEY=
FEATHERLESS_API_KEY=
